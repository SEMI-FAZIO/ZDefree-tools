{
  "$schema": "../schema.json",

  "id": "general",
  "name": "General",
  "description": {
    "en": "Default strategy — try this first. Combines QUIC fake-out, Discord/STUN voice tweaks, multisplit TLS with 4pda/google ClientHello, and game-port fallbacks.",
    "ru": "Стратегия по умолчанию — пробуй первой. QUIC-fake, голос Discord/STUN, multisplit TLS с ClientHello от 4pda/google и fallback для игровых портов."
  },
  "category": "general",
  "version": 1,
  "author": "zdefree-team (derived from Flowseal/zapret-discord-youtube)",
  "tested": "2026-05-21",

  "compat": {
    "min_winws_version": "70.0"
  },

  "filters": [
    {
      "name": "main",
      "wf": {
        "tcp": "80,443,2053,2083,2087,2096,8443,{game_tcp}",
        "udp": "443,19294-19344,50000-50100,{game_udp}"
      },

      "rules": [
        {
          "match": { "udp": "443" },
          "hostlist": ["general", "general-user"],
          "hostlist_exclude": ["exclude", "exclude-user"],
          "ipset_exclude": ["exclude", "exclude-user"],
          "desync": {
            "mode": "fake",
            "repeats": 6,
            "fake_quic": "bin/quic_initial_www_google_com.bin"
          }
        },

        {
          "match": {
            "udp": "19294-19344,50000-50100",
            "l7": ["discord", "stun"]
          },
          "desync": {
            "mode": "fake",
            "repeats": 6,
            "fake_discord": "bin/quic_initial_dbankcloud_ru.bin",
            "fake_stun":    "bin/quic_initial_dbankcloud_ru.bin"
          }
        },

        {
          "match": { "tcp": "2053,2083,2087,2096,8443" },
          "hostlist_domains": ["discord.media"],
          "desync": {
            "mode": "multisplit",
            "split_pos": "1",
            "split_seqovl": 681,
            "split_seqovl_pattern": "bin/tls_clienthello_www_google_com.bin"
          }
        },

        {
          "match": { "tcp": "443" },
          "hostlist": "google",
          "ip_id": "zero",
          "desync": {
            "mode": "multisplit",
            "split_pos": "1",
            "split_seqovl": 681,
            "split_seqovl_pattern": "bin/tls_clienthello_www_google_com.bin"
          }
        },

        {
          "match": { "tcp": "80,443" },
          "hostlist": ["general", "general-user"],
          "hostlist_exclude": ["exclude", "exclude-user"],
          "ipset_exclude": ["exclude", "exclude-user"],
          "desync": {
            "mode": "multisplit",
            "split_pos": "1",
            "split_seqovl": 568,
            "split_seqovl_pattern": "bin/tls_clienthello_4pda_to.bin"
          }
        },

        {
          "match": { "udp": "443" },
          "ipset": "all",
          "hostlist_exclude": ["exclude", "exclude-user"],
          "ipset_exclude": ["exclude", "exclude-user"],
          "desync": {
            "mode": "fake",
            "repeats": 6,
            "fake_quic": "bin/quic_initial_www_google_com.bin"
          }
        },

        {
          "match": { "tcp": "80,443,8443" },
          "ipset": "all",
          "hostlist_exclude": ["exclude", "exclude-user"],
          "ipset_exclude": ["exclude", "exclude-user"],
          "desync": {
            "mode": "multisplit",
            "split_pos": "1",
            "split_seqovl": 568,
            "split_seqovl_pattern": "bin/tls_clienthello_4pda_to.bin"
          }
        },

        {
          "match": { "tcp": "{game_tcp}" },
          "ipset": "all",
          "ipset_exclude": ["exclude", "exclude-user"],
          "desync": {
            "mode": "multisplit",
            "any_protocol": true,
            "split_pos": "1",
            "split_seqovl": 568,
            "split_seqovl_pattern": "bin/tls_clienthello_4pda_to.bin"
          },
          "advanced": {
            "cutoff": "n3"
          }
        },

        {
          "match": { "udp": "{game_udp}" },
          "ipset": "all",
          "ipset_exclude": ["exclude", "exclude-user"],
          "desync": {
            "mode": "fake",
            "repeats": 12,
            "any_protocol": true,
            "fake_unknown_udp": "bin/quic_initial_dbankcloud_ru.bin"
          },
          "advanced": {
            "cutoff": "n2"
          }
        }
      ]
    }
  ]
}
